{
  "name": "escape_room_arduino",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server/server.js",
    "dev:all": "npm run arduino:upload && concurrently \"npm run server\" \"npm run dev\"",
    "dev:all:no-arduino": "concurrently \"npm run server\" \"npm run dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/server.js",
    "arduino:upload": "arduino-cli compile --fqbn arduino:avr:uno arduino_sketch && arduino-cli upload -p /dev/cu.usbmodem* --fqbn arduino:avr:uno arduino_sketch"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "express": "^4.18.2",
    "express-session": "^1.18.2",
    "serialport": "^12.0.0",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "vite": "^7.2.4"
  }
}
